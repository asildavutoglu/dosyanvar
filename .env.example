# Google Gemini API anahtarın. Ücretsiz almak için: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opsiyonel: kullanılacak Gemini modeli
GEMINI_MODEL=gemini-2.0-flash

# Opsiyonel: GitHub API rate limitini artırmak için bir personal access token
GITHUB_TOKEN=

# Opsiyonel: Flask'ın çalışacağı port
PORT=5000
